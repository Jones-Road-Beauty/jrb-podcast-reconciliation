# Ramp developer API credentials (OAuth 2.0 client credentials)
# Get from: ramp.com → Settings → Developer → create an app → Client ID + Secret
# (NOT a single "API key" — the app exchanges these for a token automatically.)
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=

# Google Sheets API key (the app reads the sheet over HTTPS with this key)
# 1. console.cloud.google.com → your project → enable "Google Sheets API"
# 2. APIs & Services → Credentials → Create credentials → API key
# 3. The Podscale sheet must be shared as "Anyone with the link → Viewer"
GOOGLE_API_KEY=

# Podscale spreadsheet ID (do not change unless the sheet moves)
PODSCALE_SPREADSHEET_ID=1InhmO83-a7Z3U2GSGABE2AAnkoU77_fnI897J9d7sl4

# Slack incoming webhook URL for #podcast-invoices
# Apps → Incoming Webhooks → Add → select #podcast-invoices → copy URL
SLACK_WEBHOOK_URL=

# Optional: signing secret for the Ramp webhook (real-time per-invoice path).
# If set, incoming Ramp webhook calls must carry a valid x-ramp-signature.
RAMP_WEBHOOK_SECRET=

# Optional: set a secret to protect the /api/reconcile endpoint.
# If set, requests must include: Authorization: Bearer <this value>
# Vercel cron calls include this automatically when configured in the dashboard.
CRON_SECRET=
